datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum TravelCategory {
  DOMESTIC
  INTERNATIONAL
  INTERNATIONAL_RETURN
  TRAIN
  BUS
  CAB
  VISA
  VENDOR
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum JobCardStage {
  QUOTATION
  APPROVAL
  BOOKING
  VENDOR_INVOICE
  FINANCE
  RECONCILIATION
  CLOSED
}

enum RbacRole {
  TRAVEL_DESK
  TRAVEL_APPROVER
  VP_COMMERCIAL
  FINANCE
  SUPERADMIN
}

model Employee {
  employee_code             String         @id
  aadhar_pan_number         String?        @unique
  name                      String
  email                     String         @unique
  phone                     String
  designation               String
  department                String
  default_travel_approver   String
  approver_designation      String
  cost_centre               String
  default_billing_currency  String
  
  // Domestic fields
  native_city               String?
  nearest_airport           String?
  nearest_railway_station   String?
  default_mode_of_transport String?
  extra_baggage_required    Boolean?       @default(false)
  photograph_url            String?
  supporting_documents_url  String?

  // International fields
  present_location_abroad   String?
  assigned_plant_site       String?
  nearest_airport_india     String?
  passport_number           String?
  passport_issue_date       String?
  passport_expiry           String?
  passport_front_page_url   String?
  passport_back_page_url    String?
  offer_letter_url          String?
  polio_vaccine_status      String?
  polio_certificate_expiry  String?
  yfv_status                String?
  yfv_certificate_expiry    String?
  visa_number               String?
  visa_expiry_date          String?
  visa_country              String?

  // Train specific fields
  train_preferred_class     String?
  train_berth_preference    String?
  train_meal_preference     String?
  train_preferred_number    String?

  // Passport history
  passport_history          Json?          // Array of previous passport records

  // Relations
  indents                   TravelIndent[]

  created_at                DateTime       @default(now())
  profile_completed         Boolean        @default(false)
  updated_at                DateTime       @updatedAt
}

model TravelIndent {
  id                     String         @id
  travel_type            TravelCategory
  gst_applicable         Boolean
  priority               PriorityLevel
  travel_date            String
  wp_number              String?
  nearest_boarding_point String
  luggage                String?
  visa_type              String?
  visa_type_other        String?
  seat_preference        String?
  seat_preference_other  String?
  meal_preference        String?
  meal_preference_other  String?
  source_location        String
  destination            String
  purpose                String
  plant                  String?
  employee_code          String
  voided                       Boolean        @default(false)
  void_reason                  String?
  travel_approver              String?
  approver_title               String?
  indent_raiser                String?
  is_return                    Boolean        @default(false)
  domestic_connection_required Boolean        @default(false)

  // Relations
  employee               Employee       @relation(fields: [employee_code], references: [employee_code], onDelete: Cascade)
  jobCard                JobCard?

  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt

  @@index([employee_code])
}

model JobCard {
  id                          String         @id
  indentId                    String         @unique
  stage                       JobCardStage
  winningQuoteId              String?
  
  // Approval
  approvalStatus              String         // PENDING, APPROVED, REJECTED, MORE_QUOTES
  approvalNotes               String?
  approverName                String?
  approvedAt                  String?
  
  // History / Status
  voided                      Boolean        @default(false)
  void_reason                 String?
  travelApprovalStatus        String?        // PENDING, APPROVED, REJECTED
  travelApprovedBy            String?
  travelApprovedAt            String?
  travelApprovalNotes         String?
  commercialApprovalStatus    String?        // PENDING, APPROVED, REJECTED
  commercialApprovedBy        String?
  commercialApprovedAt        String?
  commercialApprovalNotes     String?
  
  // TAT Timelines
  rfqCompletedAt              String?
  l2ApprovedAt                String?
  workOrderSentAt             String?
  invoiceUploadedAt           String?
  gstInvoiceUploadedAt        String?
  
  // Relations
  indent                      TravelIndent   @relation(fields: [indentId], references: [id], onDelete: Cascade)
  quotes                      JobCardQuote[]
  auditLogs                   AuditLog[]
  rfqVendors                  Json           // Array of string vendor names
  
  booking                     Booking?
  invoice                     Invoice?
  payment                     Payment?
  rescheduling                Rescheduling?

  created_at                  DateTime       @default(now())
  updated_at                  DateTime       @updatedAt

  @@index([indentId])
}

model Booking {
  id                           String    @id @default(uuid())
  jobCardId                    String    @unique
  bookingPNR                   String?
  bookingVendor                String?
  finalBookingAmount           Float?
  bookingCurrency              String?
  ticketFileUrl                String?
  ticketFileName               String?
  ticketVendorInvoiceUrl       String?
  ticketVendorInvoiceName      String?
  cancellationChargesReturn    Float?
  cancellationReturnTicketUrl  String?
  cancellationReturnTicketName String?
  bookingRecordedAt            String?
  
  jobCard                      JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  
  created_at                   DateTime  @default(now())
  updated_at                   DateTime  @updatedAt
}

model Invoice {
  id                        String    @id @default(uuid())
  jobCardId                 String    @unique
  invoiceVendorAmount       Float?
  invoiceCurrency           String?
  invoiceNumber             String?
  gstDetailsCorrect         Boolean   @default(false)
  physicalInvoiceHandedOver Boolean   @default(false)
  varianceWarning           String?
  airlineGstInvoiceUrl      String?
  airlineGstInvoiceName     String?
  quoted_total              Float?
  actual_total              Float?
  variance_percentage       Float?
  vendor_name               String?
  attachments_url           String?
  airlineGstNumber          String?
  airlineGstAmount          Float?
  airlineGstVendorName      String?
  reconciliationRecordedAt  String?
  
  jobCard                   JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
}

model Payment {
  id                    String    @id @default(uuid())
  jobCardId             String    @unique
  financeCleared        Boolean   @default(false)
  financeVarianceReason String?
  paymentStatus         String?        // PENDING, READY, PAID
  paymentDate           String?
  paymentTransactionRef String?
  paymentMode           String?
  paymentCurrency       String?
  paymentAmountINR      Float?
  paymentRecordedAt     String?
  
  jobCard               JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
}

model Rescheduling {
  id                         String    @id @default(uuid())
  jobCardId                  String    @unique
  isCancelled                Boolean   @default(false)
  cancellationReason         String?
  cancelledAt                String?
  cancellationCharges        Float?
  cancellationGstInvoiceUrl  String?
  cancellationGstInvoiceName String?
  reschedulingCharges        Float?
  fareDifference             Float?
  reschedulingReason         String?
  parentJobCardId            String?
  rescheduledToCardId        String?
  
  jobCard                    JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
}

model JobCardQuote {
  id             String    @id
  jobCardId      String
  vendorName     String
  amount         Float
  currency       String
  quoteFileUrl   String?
  quoteFileName  String?
  isWinning      Boolean   @default(false)
  created_at     String
  airline        String?
  sector         String?
  layover        String?
  travelDate     String?
  agentName      String?
  selectedEmails Json?
  selectedPhones Json?
  travelType     String?
  visaType       String?
  cancellationChargesReturn    Float?
  cancellationReturnTicketUrl  String?
  cancellationReturnTicketName String?

  // Relations
  jobCard        JobCard   @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  updated_at     DateTime  @updatedAt

  @@index([jobCardId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  jobCardId  String
  timestamp  String
  userId     String
  action     String
  notes      String?

  // Relations
  jobCard    JobCard  @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  updated_at DateTime  @updatedAt

  @@index([jobCardId])
}

model RbacUser {
  id           String   @id
  name         String
  email        String   @unique
  role         RbacRole
  passwordHash String

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model RolePermission {
  role        RbacRole @id
  permissions Json     // Array of string permissions

  updated_at  DateTime @updatedAt
}

model RbacSettings {
  id                   Int    @id @default(1)
  senderEmail          String
  ccRecipients         String
  activeSimulatedEmail String

  updated_at           DateTime @updatedAt
}

model Vendor {
  id         String   @id
  name       String
  emails     Json     // Array of string emails
  phones     Json     // Array of string phones
  categories Json     // Array of category strings (FLIGHT, TRAIN, etc.)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Session {
  id        String   @id
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model ScanJob {
  id        String   @id
  fileType  String
  status    String   // PENDING, COMPLETED, FAILED
  result    Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublicRequest {
  id                           String   @id
  travel_type                  String
  traveler_name                String
  traveler_email               String
  traveler_phone               String
  department                   String
  designation                  String
  origin                       String
  destination                  String
  travel_date                  String
  is_return                    Boolean  @default(false)
  domestic_connection_required Boolean  @default(false)
  indent_raiser                String
  travel_approver              String
  approver_title               String
  status                       String   @default("PENDING") // PENDING, PROMOTED
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt
}

model Notification {
  id         String   @id
  userRole   String   // 'TRAVEL_DESK', 'TRAVEL_APPROVER', 'VP_COMMERCIAL', 'FINANCE', 'SUPERADMIN'
  userId     String?  // Optional specific user email
  title      String
  message    String
  read       Boolean  @default(false)
  link       String?  // SPA router hash link, e.g., '#/indents' or '#/jobcards/JC-1002'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
